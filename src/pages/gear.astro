<script>
  // ジョブフィルター: 選択ジョブが含まれる gear-group だけ表示 + ジョブアイコンをハイライト
  window.addEventListener('jobfilter', (e: any) => {
    const selected: string[] = e.detail.jobs;
    const groups = document.querySelectorAll<HTMLElement>('.gear-group');
    groups.forEach(el => {
      const jobs = (el.dataset.jobs ?? '').split(',');
      const visible = selected.length === 0 || selected.some(j => jobs.includes(j));
      el.style.display = visible ? '' : 'none';
    });

    // ジョブアイコンのハイライト
    const icons = document.querySelectorAll<HTMLElement>('.job-tag-icon');
    icons.forEach(img => {
      const job = (img as HTMLImageElement).dataset.job ?? '';
      if (selected.length === 0) {
        img.classList.remove('job-tag-icon--active', 'job-tag-icon--dim');
      } else if (selected.includes(job)) {
        img.classList.add('job-tag-icon--active');
        img.classList.remove('job-tag-icon--dim');
      } else {
        img.classList.add('job-tag-icon--dim');
        img.classList.remove('job-tag-icon--active');
      }
    });
  });
</script>

<style is:global>
.job-tag-icon {
  opacity: 0.75;
  transition: opacity 0.15s, filter 0.15s, outline 0.15s;
}
.job-tag-icon--active {
  opacity: 1;
  filter: drop-shadow(0 0 3px rgba(45,212,191,0.8));
  outline: 1px solid rgba(45,212,191,0.6);
  outline-offset: 1px;
}
.job-tag-icon--dim {
  opacity: 0.2;
}
</style>
