import BaseLayout from '../layouts/BaseLayout.astro';
import MapViewer from '../components/ui/MapViewer.svelte';
import { itemIconUrl } from '../data/items';

// ─── データ出典 ────────────────────────────────────────────────────────────────
// 銀箱座標: https://asellog.com/oc-treasure/
// ドロップ率: https://game8.jp/ff14/696125
// エーテライト: story.astro と同一データ
