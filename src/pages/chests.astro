// ゲーム座標 → SVGピクセル変換
// Map.csv: SizeFactor=100, OffsetX=0, OffsetY=0 → ゲーム座標範囲 1〜42
// pixel = (gx - 1) / 41 * 800
const g2p = (gx: number, gy: number) => ({
  x: Math.round(((gx - 1) / 41) * 800),
  y: Math.round(((gy - 1) / 41) * 800),
});

