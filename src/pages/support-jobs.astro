import { itemIconUrl } from '../data/items';

const _img = (id: number) => `<img src="${itemIconUrl(id)}" alt="" class="inline align-middle w-4 h-4 rounded mr-0.5" style="image-rendering:pixelated">`;
const withIcons = (text: string) => text
  .replace(/十二都市銀貨/g, `${_img(65119)}十二都市銀貨`)
  .replace(/十二都市金貨/g, `${_img(65118)}十二都市金貨`);

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const jobIconUrl   = (id: string) => `${BASE}/icons/support-jobs/${id}.png`;
const crestIconUrl = (id: string) => `${BASE}/icons/support-jobs/crests/${id}.png`;
const actIconUrl  = (icon: number) => `${BASE}/icons/support-jobs/actions/${String(icon).padStart(6,'0')}.png`;
const buffIconUrl = (id: string) => `${BASE}/icons/support-jobs/buffs/${id}.png`;

type ExpRow = { lv: number; exp: number | null };
type SubAction = { name: string; icon: number };
type Action = {
  lv: number;
  name: string;
  cast: string;
  recast: string;
  duration: string;
  type: string;
  effect: string;
  extra?: string;
  icon?: number;
  subActions?: SubAction[];
};
type Job = {
  id: string;
  name: string;
  color: string;
  acquire: string;
  patch?: string;
  specialExp?: string;
  exps: ExpRow[];
  masterExp: number;
  actions: Action[];
};
type Group = { id: string; label: string; jobs: Job[] };

const groups: Group[] = [
