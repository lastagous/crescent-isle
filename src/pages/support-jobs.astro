        masterExp: 19200,
        actions: [
          { lv:1, name:'マギ・ダッシュ',    cast:'instant', recast:'30秒',           duration:'10秒', type:'アビリティ', icon:64568, effect:'自身の移動速度を大幅に上昇させる。' },
          { lv:2, name:'ぬすむ',            cast:'instant', recast:'30秒',           duration:'-',    type:'アビリティ', icon:64567, effect:'このアクションを命中させてから敵を倒すと、より多くのアイテムを獲得できることがある。' },
          { lv:3, name:'けいかい',          cast:'instant', recast:'10秒',           duration:'20秒', type:'アビリティ', icon:64569, effect:'自身に「けいかい」を付与する。非戦闘中にクリティカル発動率を60%上昇させる。戦闘開始後20秒間効果が持続するが、CEや一部コンテンツでは効果が解除される。' },
          { lv:4, name:'トラップかんち',   cast:'instant', recast:'5秒',            duration:'20秒', type:'アビリティ', icon:64570, effect:'一定時間、周囲15m以内にあるフォークタワー専用の隠し通路や罠を感知できるようになる。' },
          { lv:5, name:'ぶきをぬすむ',     cast:'instant', recast:'60秒（非固有）', duration:'60秒', type:'アビリティ', icon:64571, effect:'対象の物理攻撃力を10%減少させる。' },
          { lv:6, name:'かぎあけ',         cast:'instant', recast:'5秒',            duration:'-',    type:'アビリティ',           effect:'フォークタワー内の鍵のかかった扉を開ける。' },
        ],
      },
      {
        id: 'gladiator', name: '剣闘士', color: '#fb923c',
        acquire: '十二都市金貨 1,600 枚',
        patch: '7.4',
        exps: [{ lv:2,exp:400},{ lv:3,exp:null},{ lv:4,exp:null},{ lv:5,exp:null},{ lv:6,exp:null}],
        masterExp: 14400,
        actions: [
          { lv:1, name:'ひっさつ',      cast:'instant', recast:'60秒（非固有）', duration:'-',   type:'ウェポンスキル', icon:64579, effect:'対象に物理攻撃。大成功（20%）：威力1000。成功（60%）：威力600。失敗（20%）：命中しない。（IL依存）' },
          { lv:2, name:'ぼうぎょ',      cast:'instant', recast:'30秒',           duration:'5秒', type:'アビリティ',    icon:64580, effect:'自身の被ダメージを50%軽減する。', extra:'軽減成功時に「ひっさつ強化」を付与（最大4スタック、120秒）。リキャスト中でない時に攻撃を受けると1スタック減少する。' },
          { lv:3, name:'こうれつぎり', cast:'instant', recast:'120秒（非固有）', duration:'-',   type:'ウェポンスキル', icon:64581, effect:'対象に物理攻撃。威力：400（IL依存）' },
          { lv:4, name:'ぜんぎり',      cast:'instant', recast:'30秒（非固有）', duration:'-',   type:'ウェポンスキル', icon:64582, effect:'自身の周囲の敵に範囲物理攻撃。威力：200（IL依存）ひっさつ強化中は威力が上昇する。' },
        ],
      },
    ],
  },
];

// EXP サマリーテーブル用データ（合計EXP → ジョブ名リスト）
const expSummary = new Map<number, string[]>();
for (const g of groups) {
  for (const j of g.jobs) {
    if (!expSummary.has(j.masterExp)) expSummary.set(j.masterExp, []);
    expSummary.get(j.masterExp)!.push(j.name);
  }
}
const expRows = [...expSummary.entries()].sort((a, b) => a[0] - b[0]);

// 目次データ
const tocItems = [
  { id: 'section-master-bonus', label: 'ジョブマスターボーナス' },
  { id: 'section-exp-summary',  label: '必要EXP早見表' },
  ...groups.map(g => ({
    id: g.id,
    label: g.label,
    sub: g.jobs.map(j => ({ id: j.id, label: j.name, icon: crestIconUrl(j.id) })),
  })),
];
---

<BaseLayout
  title="サポートジョブ一覧 | クレセントアイル | FF14"
  description="FF14 クレセントアイル（パッチ 7.4）のサポートジョブ全16種。入手方法・各レベル必要EXP・アクション詳細一覧。"
>
  <div class="page-hero">
    <div class="container mx-auto px-4 pt-16 pb-8 relative z-10">
      <h1 class="font-display text-4xl md:text-5xl text-moon-light">サポートジョブ一覧</h1>
    </div>
  </div>

  <!-- 2カラムレイアウト: コンテンツ + 右サイドTOC -->
  <div class="container mx-auto px-4 py-12 max-w-6xl">
    <div class="flex gap-8 relative">

      <!-- メインコンテンツ -->
      <div class="min-w-0 flex-1">

        <!-- ジョブマスターボーナス -->
        <section id="section-master-bonus" class="mb-8" data-toc>
          <h2 class="font-display text-sm text-moon-dim uppercase tracking-widest mb-5 border-b border-night-300/60 pb-2">ジョブマスターボーナス</h2>
          <div class="section-card">
            <p class="text-slate text-sm leading-relaxed mb-4">
              サポートジョブをマスター（レベル上限まで育成）するたびに、<span class="text-teal font-semibold">与ダメージ・与回復量が恒久的に +2%</span> されます。効果はジョブ変更後も持続し、クレセントアイル滞在中は常に有効です。
              バフアイコン「ファントムマスタリー」がスタックで表示されます（最大15）。
            </p>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-2 text-sm text-center">
              {[1,3,5,10,15].map(n => (
                <div class="bg-teal/5 border border-teal/20 rounded-lg py-2 px-2">
                  <div class="text-[0.65rem] text-moon-dim tracking-wider mb-0.5">{n}種マスター</div>
                  <div class="font-mono text-teal font-semibold text-lg">+{n*2}%</div>
                </div>
              ))}
            </div>
            <p class="text-slate/50 text-xs mt-3">※ パッチ 7.4 時点で最大 15 種マスター → +30% が上限</p>
          </div>
        </section>

        <!-- EXP早見表 -->
        <section id="section-exp-summary" class="mb-8" data-toc>
          <h2 class="font-display text-sm text-moon-dim uppercase tracking-widest mb-5 border-b border-night-300/60 pb-2">マスター必要EXP早見表</h2>
          <div class="section-card">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="border-b border-[var(--color-border)]">
                  <th class="text-left py-2 px-3 text-moon-dim font-normal text-xs">マスター合計EXP</th>
                  <th class="text-left py-2 px-3 text-moon-dim font-normal text-xs">ジョブ</th>
                </tr>
              </thead>
              <tbody>
                {expRows.map(([total, jobs]) => (
                  <tr class="border-b border-night-300/40 last:border-0">
                    <td class="py-2 px-3 font-mono text-teal font-semibold">{total.toLocaleString()}</td>
                    <td class="py-2 px-3 text-slate">{jobs.join('、')}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ジョブ一覧 -->
        {groups.map(group => (
          <div class="mb-12" id={group.id} data-toc>
            <h2 class="font-display text-sm text-moon-dim uppercase tracking-widest mb-5 border-b border-night-300/60 pb-2">
              <Fragment set:html={withIcons(group.label)} />
            </h2>

            <div class="flex flex-col gap-6">
              {group.jobs.map(job => (
                <div class="section-card" id={job.id} data-toc>

                  {/* ジョブヘッダー */}
                  <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                    <div class="flex items-center gap-3">
                      <img
                        src={jobIconUrl(job.id)}
                        alt={job.name}
                        class="w-10 h-10 rounded-lg flex-shrink-0 object-contain"
                        style="image-rendering:pixelated"
                      />
                      <div>
                        <div class="flex items-center gap-2 flex-wrap">
                          <span class="font-display font-semibold text-moon-light text-lg">{job.name}</span>
                          {job.patch && (
                            <span class="text-[0.65rem] px-1.5 py-0.5 rounded border bg-crimson/10 text-crimson border-crimson/30 font-mono">Patch {job.patch}</span>
                          )}
                        </div>
                        <div class="text-xs text-slate mt-0.5" set:html={withIcons(job.acquire)} />
                      </div>
                    </div>
                    <div class="flex items-center gap-4">
                      <img src={crestIconUrl(job.id)} alt={job.name} class="w-7 h-7 object-contain" style="filter:drop-shadow(0 0 3px rgba(212,175,55,0.5))" />
                      <div class="text-right">
                        <div class="text-[0.65rem] text-slate uppercase tracking-wider">マスター EXP</div>
                        <div class="font-mono text-teal font-semibold text-xl">{job.masterExp.toLocaleString()}</div>
                      </div>
                    </div>
                  </div>

                  {/* すっぴん専用説明 */}
                  {job.specialExp && (
                    <div class="mb-4 p-3 rounded-lg bg-night-300/40 border border-night-300/60 text-xs text-slate leading-relaxed">
                      {job.specialExp}
                    </div>
                  )}

                  {/* EXP テーブル（Lv2〜Lv6） */}
                  {job.exps.length > 0 && (
                    <div class="mb-4 overflow-x-auto">
                      <table class="text-xs border-collapse" style="table-layout:fixed">
                        <colgroup>
                          {job.exps.map(() => <col style="width:5.5rem" />)}
                          <col style="width:5.5rem" />
                        </colgroup>
                        <thead>
                          <tr class="border-b border-[var(--color-border)]">
                            {job.exps.map(r => (
                              <th class="text-center py-1 px-3 text-moon-dim font-normal whitespace-nowrap">Lv{r.lv}</th>
                            ))}
                            <th class="text-center py-1 px-3 text-moon-dim font-normal">合計</th>
                          </tr>
                        </thead>
                        <tbody>
                          <tr>
                            {job.exps.map(r => (
                              <td class="text-center py-1 px-3 font-mono">
                                {r.exp !== null
                                  ? <span class="text-teal">{r.exp.toLocaleString()}</span>
                                  : <span class="text-slate/40">-</span>
                                }
                              </td>
                            ))}
                            <td class="text-center py-1 px-3 font-mono text-moon font-semibold">
                              {job.masterExp.toLocaleString()}
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  )}

                  {/* アクションテーブル */}
                  <div class="overflow-x-auto">
                    <table class="w-full text-xs border-collapse">
                      <thead>
                        <tr class="border-b border-[var(--color-border)]">
                          <th class="text-left py-1.5 px-2 text-moon-dim font-normal w-6">Lv</th>
                          <th class="text-left py-1.5 px-2 text-moon-dim font-normal w-36">アクション名</th>
                          <th class="text-center py-1.5 px-2 text-moon-dim font-normal w-20">キャスト</th>
                          <th class="text-center py-1.5 px-2 text-moon-dim font-normal w-24">リキャスト</th>
                          <th class="text-center py-1.5 px-2 text-moon-dim font-normal w-20">効果時間</th>
                          <th class="text-left py-1.5 px-2 text-moon-dim font-normal w-16">種類</th>
                          <th class="text-left py-1.5 px-2 text-moon-dim font-normal">効果 / 追加効果</th>
                        </tr>
                      </thead>
                      <tbody>
                        {job.actions.map(a => (
                          <tr class="border-b border-night-300/40 last:border-0 hover:bg-night-300/20">
                            <td class="py-2 px-2 align-top font-mono text-teal/70">{a.lv}</td>
                            <td class="py-2 px-2 align-top text-moon font-medium leading-snug">
                              <span class="flex items-center gap-1.5">
                                {a.icon && (
                                  <img
                                    src={actIconUrl(a.icon)}
                                    alt=""
                                    class="w-6 h-6 flex-shrink-0 rounded"
                                    loading="lazy"
                                  />
                                )}
                                {!a.icon && (
                                  <span class="w-6 h-6 flex-shrink-0 inline-block"></span>
                                )}
                                <span>{a.name}</span>
                              </span>
                            </td>
                            <td class="py-2 px-2 align-top text-center text-slate/70 font-mono">{a.cast}</td>
                            <td class="py-2 px-2 align-top text-center text-slate/70 font-mono">{a.recast}</td>
                            <td class="py-2 px-2 align-top text-center text-slate/70 font-mono">{a.duration}</td>
                            <td class="py-2 px-2 align-top text-slate/60">{a.type}</td>
                            <td class="py-2 px-2 align-top text-slate leading-relaxed">
                              {a.effect}
                              {a.extra && (
                                <span class="block mt-1 text-slate/70">{a.extra}</span>
                              )}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>

                </div>
              ))}
            </div>
            {group.id === 'group-quest' && (
              <div class="mt-4">
                <a href="./story" class="text-xs text-teal/80 hover:text-teal transition-colors">ストーリー攻略を見る →</a>
              </div>
            )}
            {group.id === 'group-ce' && (
              <div class="mt-4">
                <a href="./fate" class="text-xs text-teal/80 hover:text-teal transition-colors">FATE・CE 攻略一覧を見る →</a>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- 右サイドバー：目次 -->
      <!-- aside は stretch（デフォルト）のままにして、内部の sticky nav が追従できる高さを確保 -->
      <aside class="hidden xl:block w-52 flex-shrink-0">
        <TableOfContents client:visible items={tocItems} />
      </aside>

    </div>
  </div>
</BaseLayout>
