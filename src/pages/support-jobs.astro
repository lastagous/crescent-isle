          { lv:5, name:'ベル効果アップ', cast:'-',        recast:'-',              duration:'-',              type:'特性', icon:82210, effect:'「たたかいのベル」の効果量を5%に上昇させる。「いこいのベル」の回復力を3000に上昇させる。' },
