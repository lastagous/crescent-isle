        actions: [
          { lv:1, name:'みねうち',           cast:'instant',        recast:'10秒（非固有）', duration:'6秒', type:'ウェポンスキル', icon:64776, effect:'対象をスタンさせる。' },
          { lv:2, name:'しらはどり',         cast:'instant',        recast:'30秒',           duration:'4秒', type:'アビリティ',    icon:64777, effect:'自身が受ける物理攻撃を1度だけ無効化する。' },
          { lv:3, name:'いあいぬき',         cast:'1.5秒（非固有）', recast:'40秒（非固有）', duration:'-',   type:'ウェポンスキル', icon:64778, effect:'対象に向かって前方扇範囲物理攻撃。威力：300（IL依存）10%の確率で即死効果が発動する。' },
          { lv:4, name:'ぜになげ',           cast:'instant',        recast:'60秒（非固有）', duration:'-',   type:'ウェポンスキル', icon:64779, effect:'対象に物理攻撃。威力：1500（IL依存）発動条件：古びた銭箱の所持。' },
          { lv:5, name:'いあいぬき効果アップ', cast:'-',             recast:'-',              duration:'-',   type:'特性', icon:82208, effect:'「いあいぬき」の威力を400に上昇させる。' },
        ],
      },
      {
        id: 'thief', name: 'シーフ', color: '#94a3b8',
