---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TocObserver from '../../components/ui/TocObserver.svelte';
import { TOMES } from '../../data/tomes';
import { itemIconUrl, ITEM_ICONS } from '../../data/items';

// ─── サポートジョブ一覧 ─────────────────────────────────────────────────────
const supportJobs = [
  { job: 'シーフ',       icon: 'thief',      req: '×2〜4 必須',      role: '全道中のトラップ探知・鍵開け・バフ剥がし' },
  { job: '風水士',       icon: 'geomancer',  req: '×2〜3 必須',      role: '全道中の帯電床通過・プリント起動' },
  { job: '時魔道士',     icon: 'timemage',   req: '×2〜4 必須',      role: '1ボス・道中2の詠唱遅延・デスペル' },
  { job: '吟遊詩人',     icon: 'bard',       req: '×2〜6 必須',      role: '2ボス・3ボスのスプライト凍結' },
  { job: 'ナイト',       icon: 'knight',     req: '各PTY ×1 必須',   role: '全ボスの全体軽減・砲台ポジション' },
  { job: 'バーサーカー', icon: 'berserker',  req: '全体 ×1 必須',    role: '4ボスの紫コンデュイット専用破壊' },
  { job: '薬師',         icon: 'chemist',    req: '各PTY ×1 必須',   role: '全区間の唯一の蘇生源' },
  { job: '狩人',         icon: 'ranger',     req: '各PTY ×1 推奨',   role: '道中1・2ボスのトラップ処理・軽減' },
  { job: '砲撃士',       icon: 'cannoneer',  req: '推奨',             role: '1ボス・道中3の即死・脆弱スタック' },
  { job: '侍',           icon: 'samurai',    req: '推奨',             role: '1ボス・道中3の即死・物理回避' },
  { job: '予言士',       icon: 'oracle',     req: '任意',             role: '道中3のガーディアン遅延即死' },
];

// ─── 参考動画データ（イディル式 / ぬけまる準拠） ────────────────────────────
// ※ YouTube動画ID を各 videoId に入力してください
const videos = {
  boss1:  { title: 'フォークタワー 1ボス デモンズタブレット解説【ぬけまる】', videoId: 'VQGiyw7tuYo', channel: 'ぬけまるG', url: 'https://nukemarugames.com/' },
  trash1: { title: 'フォークタワー 道中1解説【ぬけまる】',                    videoId: '',             channel: 'ぬけまるG', url: 'https://nukemarugames.com/' },
  boss2:  { title: 'フォークタワー 2ボス デッドスターズ解説【ぬけまる】',     videoId: 'e3c7veLHTXI', channel: 'ぬけまるG', url: 'https://nukemarugames.com/' },
  trash2: { title: 'フォークタワー 道中2解説【犬丸のぞみ】',                  videoId: '3F1D-aEYA0E', channel: '犬丸のぞみ', url: 'https://www.youtube.com/@inumaru_nozomi' },
  boss3:  { title: 'フォークタワー 3ボス マーブルドラゴン解説【ぬけまる】',   videoId: 'HvySz9r8mNM', channel: 'ぬけまるG', url: 'https://nukemarugames.com/' },
  trash3: { title: 'フォークタワー 道中3解説【犬丸のぞみ】',                  videoId: 'ynE_fiRsFnM', channel: '犬丸のぞみ', url: 'https://www.youtube.com/@inumaru_nozomi' },
  boss4:  { title: 'フォークタワー 4ボス マギタウロス解説【ぬけまる】',        videoId: 'Z55g6ARpbJ0', channel: 'ぬけまるG', url: 'https://nukemarugames.com/' },
};
---

<BaseLayout
  title="フォークタワー：力の塔 攻略ガイド（イディル式）| クレセントアイル | FF14"
  description="FF14 クレセントアイルのフォークタワー：力の塔をイディル式で徹底解説。入場方法・4ボス全ギミック・散開図・サポートジョブ・タイムライン・報酬まで網羅。"
>
  <!-- Hero -->
  <div class="page-hero">
    <div class="container mx-auto px-4 pt-16 pb-8 relative z-10">
      <h1 class="font-display text-4xl md:text-5xl text-moon-light">
        フォークタワー：<span class="text-crimson">力の塔</span>
      </h1>
      <p class="text-xs text-slate mt-2">イディル式（野良標準）準拠</p>
    </div>
  </div>

  <!-- Page body -->
  <div class="container mx-auto px-4 py-10 max-w-6xl">

    <!-- 2カラムレイアウト -->
    <div class="tower-layout">

      <!-- ── メインコンテンツ ─────────────────────────────────────────── -->
      <div class="tower-main">

        <!-- ═══ 入場・概要 ══════════════════════════════════════════════ -->
        <section id="entry" class="section-card mb-8 border-teal">
          <h2 class="font-display text-sm text-moon-dim uppercase tracking-widest mb-5 border-b border-night-300/60 pb-2">入場条件と蜃気楼ルール</h2>
          <div class="grid md:grid-cols-2 gap-4 text-sm">
            <div>
              <h3 class="subsection-label">入場フロー</h3>
              <ol class="space-y-1.5 text-xs text-slate leading-relaxed list-decimal list-inside">
                <li>遠征古物商で「<img src={itemIconUrl(65121)} alt="" class="inline align-middle w-4 h-4 rounded mr-0.5" style="image-rendering:pixelated" />魔紋起動証：力の塔」を購入（銀貨・金貨で入手）</li>
                <li>外部 Discord 等で48名の編成を組む</li>
                <li>天候「蜃気楼」の発生を確認（空が赤紫色に変化）</li>
                <li>フィールド中央「静寂の東屋」近くの遺物殿で証を供託</li>
                <li>24名以上が供託するとエーテリアルノード起動 → 入場可能</li>
                <li>48名超の場合は抽選（供託数多い順で優先）</li>
              </ol>
            </div>
            <div>
              <h3 class="subsection-label">蜃気楼タイマー</h3>
              <ul class="space-y-1.5 text-xs text-slate leading-relaxed">
                <li>インスタンス生成から <strong class="text-moon-light">5分後</strong>（24名以上在線時）に初回発動</li>
                <li>通常リスポーンタイマー: <strong class="text-moon-light">60分</strong></li>
                <li>CE クリアごとに <strong class="text-teal">−5分</strong> 短縮</li>
                <li>FATE クリアごとに <strong class="text-teal">−1分</strong> 短縮</li>
                <li>天候ウィンドウは約 <strong class="text-moon-light">5分間</strong></li>
              </ul>
              <h3 class="subsection-label mt-4">全滅ペナルティ</h3>
              <ul class="space-y-1.5 text-xs text-slate leading-relaxed">
                <li>レベルダウン（CE 1回 + FATE 1〜2回程度で回復）</li>
                <li>蘇生は <strong class="text-crimson">薬師のそせいのみ</strong>（通常レイズ系は機能しない）</li>
                <li>蘇生スタック ×3 → 0で以降蘇生不可</li>
                <li>ギミックミス刻印 3回 = 即死（死の宣告）</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- ═══ スタートルーム ══════════════════════════════════════════ -->
        <section id="start" class="tower-section mb-8">
          <div class="ts-header prep-header">
            <div class="ts-title-group">
              <span class="ts-badge badge-prep">準備</span>
              <h2 class="ts-title">スタートルーム — イディル式ウェイマーク・ジョブ確認</h2>
            </div>
          </div>
          <div class="ts-body">
            <h4>入場後の流れ</h4>
            <ul>
              <li>ここを出た瞬間に「デューティー・アズ・アサインド」デバフ付与 → <span class="warn">以降サポートジョブ変更不可</span></li>
              <li>各アライアンス（A/B/C）でウェイマーク共有・役割確認を行う</li>
            </ul>
            <h4>イディル式 アライアンス割り当て（全ボス共通基準）</h4>
            <div class="marker-table-wrap">
              <table class="marker-table">
                <thead><tr><th>アライアンス</th><th>カラー</th><th>担当</th><th>ウェイマーク</th></tr></thead>
                <tbody>
                  <tr><td>アライアンス 1（文字班 A）</td><td><span class="dot dot-a"></span>北西</td><td>北西ルート / A島</td><td>A マーカー</td></tr>
                  <tr><td>アライアンス 2（文字班 B）</td><td><span class="dot dot-b"></span>北東</td><td>北東ルート / B島</td><td>B マーカー</td></tr>
                  <tr><td>アライアンス 3（数字班 C）</td><td><span class="dot dot-c"></span>南</td><td>南ルート / C島</td><td>C マーカー</td></tr>
                </tbody>
              </table>
            </div>
            <h4>必須ジョブ数（48名編成の目安）</h4>
            <ul>
              <li><strong>シーフ</strong> ×2〜4 — 左右ルート各1人以上。トラップ感知・錠前・武器強奪</li>
              <li><strong>風水士</strong> ×2〜3 — ふゆうで帯電床通過・たたかいのベル起動</li>
              <li><strong>時魔道士</strong> ×2〜4 — 1ボスから必須。マギ・デスペル / マギ・スロウガ</li>
              <li><strong>吟遊詩人</strong> ×2〜6 — あいのうた（2ボス後・3ボスで必須）</li>
              <li><strong>ナイト</strong> 各アライアンス ×1 — まもり（全体軽減）・4ボス砲台担当</li>
              <li><strong>バーサーカー</strong> 全体 ×1 — 4ボス紫コンデュイット破壊専任</li>
              <li><strong>薬師</strong> 各アライアンス ×1 — そせいがない班は機能停止リスクあり</li>
            </ul>
          </div>
        </section>

        <!-- ═══ ボス1 ══════════════════════════════════════════════════ -->
        <section id="boss1" class="tower-section mb-8">
          <div class="ts-header boss-header">
            <div class="ts-title-group">
              <span class="ts-badge badge-boss">Boss 1</span>
              <h2 class="ts-title">デモンズタブレット</h2>
            </div>
          </div>
          <div class="ts-body">

            <h4>必須サポートジョブ</h4>
            <div class="job-chips">
              <span class="job-chip req"><img src="/icons/support-jobs/timemage.png" class="job-chip-icon" alt="" />時魔道士 ×2</span>
              <span class="job-chip req"><img src="/icons/support-jobs/knight.png" class="job-chip-icon" alt="" />ナイト 各PTY ×1</span>
              <span class="job-chip rec"><img src="/icons/support-jobs/cannoneer.png" class="job-chip-icon" alt="" />砲撃士 推奨</span>
              <span class="job-chip rec"><img src="/icons/support-jobs/samurai.png" class="job-chip-icon" alt="" />侍 推奨</span>
            </div>

            <h4>マーカー配置（イディル式）</h4>
            <ul>
              <li>南北 3塔ずつ、計 6塔 の位置に <strong>A/B/C/1/2/3</strong> マーカーを配置</li>
              <li>担当: アライアンス1 → 前左塔、アライアンス2 → 後中塔、アライアンス3 → 前右塔（南北対称）</li>
              <li><strong>開幕LB推奨:</strong> キャスター LB2 を開幕前に押す（LB2 = 5秒前）</li>
            </ul>

            <h4>ギミック詳細</h4>
            <ul>
              <li><strong>デモンズダーラ</strong> — 開幕魔法全体攻撃。軽減・バリア必須</li>
              <li><strong>排斥式 / 圧潰式 ダークレイ</strong> — 「排斥式」= ボスから離れる。「圧潰式」= ボスへ近づく。フィールド半分が安置</li>
              <li><strong>グリフマギア</strong> — ヘイスト上位 3名へのタンクバスター。他プレイヤーはクリーヴ範囲外へ</li>
              <li><strong>排斥式 / 圧潰式 デモンズグリフ</strong> — 南北に 3塔ずつ計 6塔出現、各塔に 4名ずつ入る（計 24名）。不足時は爆発 → <span class="warn">デバフ付与</span></li>
              <li><strong>レフト / ライトターン</strong> — ボスの詠唱方向と<span class="tip">逆方向</span>へ移動。90°回転 ×2 後に即死ビーム</li>
              <li><strong>排斥式 / 圧潰式 デモンズコメテオ</strong> — メテオマーカー付きプレイヤーはフィールド端へ移動して AoE 捨て</li>
              <li><strong>召喚（雑魚フェーズ）</strong> — サモンド・デーモン / アーチ・デーモン 出現。防御バフあり → <strong>マギ・デスペル で必ず解除してから攻撃</strong></li>
            </ul>

            <h4>タイムライン</h4>
            <ol class="timeline">
              <li><span class="tl-t">00:00</span> デモンズダーラ（全体）</li>
              <li><span class="tl-t">〜:XX</span> ダークレイ（離/近）</li>
              <li><span class="tl-t">〜:XX</span> デモンズグリフ（6塔）</li>
              <li><span class="tl-t">〜:XX</span> グリフマギア（タンクバスター）</li>
              <li><span class="tl-t">〜:XX</span> レフト/ライトターン → 即死ビーム</li>
              <li><span class="tl-t">〜:XX</span> デモンズコメテオ（メテオ捨て）</li>
              <li><span class="tl-t">〜:XX</span> 召喚（雑魚 + デスペル）</li>
              <li><span class="tl-t">6:40</span> <span class="warn">エンレイジ エンド・オブ・ヒストリー</span></li>
            </ol>

            <h4>参考動画</h4>
            {videos.boss1.videoId ? (
              <div class="video-grid">
                <a href={`https://www.youtube.com/watch?v=${videos.boss1.videoId}`} class="video-card" target="_blank" rel="noopener">
                  <img src={`https://img.youtube.com/vi/${videos.boss1.videoId}/hqdefault.jpg`} alt={videos.boss1.title} class="video-thumb" loading="lazy" />
                  <div class="video-info"><div class="video-title">{videos.boss1.title}</div><div class="video-ch">{videos.boss1.channel}</div></div>
                </a>
              </div>
            ) : (
              <div class="ref-links">
                <a href="https://game8.jp/ff14/698605" class="ref-link" target="_blank" rel="noopener">game8 1ボス詳細攻略</a>
                <a href={videos.boss1.url} class="ref-link" target="_blank" rel="noopener">ぬけまるG 攻略ブログ</a>
              </div>
            )}
          </div>
        </section>

        <!-- ═══ 道中1 ════════════════════════════════════════════════ -->
        <section id="trash1" class="tower-section mb-8">
          <div class="ts-header trash-header">
            <div class="ts-title-group">
              <span class="ts-badge badge-trash">道中 1</span>
              <h2 class="ts-title">トラップ回廊</h2>
            </div>
          </div>
          <div class="ts-body">

            <h4>必須サポートジョブ</h4>
            <div class="job-chips">
              <span class="job-chip req"><img src="/icons/support-jobs/thief.png" class="job-chip-icon" alt="" />シーフ 左右各 ×1（先頭必須）</span>
              <span class="job-chip req"><img src="/icons/support-jobs/geomancer.png" class="job-chip-icon" alt="" />風水士 ×1〜2</span>
              <span class="job-chip rec"><img src="/icons/support-jobs/ranger.png" class="job-chip-icon" alt="" />狩人 推奨（遠隔トラップ処理）</span>
            </div>

            <h4>進行概要</h4>
            <ul>
              <li>アライアンス 1/2/3 が左・中央・右ルートを同時進行</li>
              <li>シーフが先頭でトラップ探知。帯電床は風水士の <strong>ふゆう</strong> で安全通過</li>
              <li><span class="warn">ダッシュ技使用禁止</span>（トラップ起動に繋がる）</li>
            </ul>

            <h4>トラップ種別</h4>
            <ul>
              <li><strong>通常トラップ</strong> — 爆発（近接死亡）。狩人の マギ・ファルコン で遠隔解除可。タンク無敵カバーも可</li>
              <li><strong>不安定（スーパー）トラップ</strong> — 広域大爆発。全員後退後にタンク無敵でのみ安全処理</li>
              <li><strong>帯電床</strong> — 踏むと即死＋出血。ふゆう か タンク無敵で突破</li>
              <li><strong>緑オーブ</strong> — 近接 AoE ＋ 60秒サイレンス（解除不可）。魔法使いは絶対近づかない</li>
            </ul>

            <h4>主要敵</h4>
            <ul>
              <li><strong>タワー・マンティコア</strong> — 左/右ハンマー（180°扇）×2。1発目が遅く2発目が反転速攻。予測回避必要</li>
              <li><strong>タワー・スカラブ</strong> — ライノ・ガードバフ（回避率上昇）付き。<strong>マギ・デスペル で解除してから攻撃</strong></li>
            </ul>

            <h4>参考動画</h4>
            {videos.trash1.videoId ? (
              <div class="video-grid">
                <a href={`https://www.youtube.com/watch?v=${videos.trash1.videoId}`} class="video-card" target="_blank" rel="noopener">
                  <img src={`https://img.youtube.com/vi/${videos.trash1.videoId}/hqdefault.jpg`} alt={videos.trash1.title} class="video-thumb" loading="lazy" />
                  <div class="video-info"><div class="video-title">{videos.trash1.title}</div><div class="video-ch">{videos.trash1.channel}</div></div>
                </a>
              </div>
            ) : (
              <div class="ref-links">
                <a href={videos.trash1.url} class="ref-link" target="_blank" rel="noopener">ぬけまるG 攻略ブログ</a>
              </div>
            )}
          </div>
        </section>

        <!-- ═══ ボス2 ══════════════════════════════════════════════════ -->
        <section id="boss2" class="tower-section mb-8">
          <div class="ts-header boss-header">
            <div class="ts-title-group">
              <span class="ts-badge badge-boss">Boss 2</span>
              <h2 class="ts-title">デッドスターズ</h2>
            </div>
          </div>
          <div class="ts-body">

            <h4>必須サポートジョブ</h4>
            <div class="job-chips">
              <span class="job-chip req"><img src="/icons/support-jobs/thief.png" class="job-chip-icon" alt="" />シーフ（ぶきをぬすむ）</span>
              <span class="job-chip req"><img src="/icons/support-jobs/geomancer.png" class="job-chip-icon" alt="" />風水士（ふゆう）</span>
              <span class="job-chip req"><img src="/icons/support-jobs/ranger.png" class="job-chip-icon" alt="" />狩人 各PTY ×1</span>
              <span class="job-chip req"><img src="/icons/support-jobs/bard.png" class="job-chip-icon" alt="" />吟遊詩人 ×2以上（あいのうた）</span>
            </div>

            <h4>マーカー配置・担当振り分け（イディル式）</h4>
            <div class="marker-table-wrap">
              <table class="marker-table">
                <thead><tr><th>ボス</th><th>属性</th><th>位置</th><th>担当</th></tr></thead>
                <tbody>
                  <tr><td>フォーボス</td><td><span class="dot dot-green"></span>緑</td><td>SW（南西）</td><td>アライアンス 1（A/1）</td></tr>
                  <tr><td>トライトン</td><td><span class="dot dot-red"></span>赤</td><td>N（北）</td><td>アライアンス 2（B/2）</td></tr>
                  <tr><td>ネレゲイド</td><td><span class="dot dot-blue"></span>青</td><td>SE（南東）</td><td>アライアンス 3（C/3）</td></tr>
                </tbody>
              </table>
            </div>
            <ul>
              <li>「決戦」詠唱中に各ボスに1人でも当てられた属性デバフが付くと、そのボスにしかダメージを与えられなくなる → <span class="warn">誤ボスへの攻撃厳禁</span></li>
            </ul>

            <h4>ギミック詳細</h4>
            <ul>
              <li><strong>サテライトコンビネーション 1（スライム）</strong> — フォーボスが無敵化、残2体がスライム化。<span class="tip">自分に付いたデバフ色と反対色</span>のスライム AoE に乗って相殺。未相殺は即死</li>
              <li><strong>リベンジファイガ / リベンジブリザガ</strong> — 飛翔した2体から超巨大扇範囲。<span class="tip">飛んだ方向が安置</span></li>
              <li><strong>デルタアタック</strong> — 魔法全体攻撃。バリアヒーラー・シールド必須</li>
              <li><strong>重火砲（ヘビーアーティレリー）</strong> — 頭割り。外周方向へビームが飛ぶよう位置取り</li>
